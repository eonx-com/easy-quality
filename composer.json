{
    "name": "eonx-com/easy-quality",
    "description": "Makes using of code quality tools for PHP projects of EonX easier",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "~8.4",
        "jangregor/phpstan-prophecy": "2.3.0",
        "phpmd/phpmd": "2.15.0",
        "phpstan/phpdoc-parser": "2.3.2",
        "phpstan/phpstan": "2.1.40",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "2.3.8",
        "savinmikhail/add_named_arguments_rector": "^0.1.25",
        "slevomat/coding-standard": "8.28.0",
        "symplify/easy-coding-standard": "13.0.4",
        "symplify/phpstan-extensions": "12.0.2",
        "symplify/phpstan-rules": "14.9.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "EonX\\EasyQuality\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EonX\\EasyQuality\\Tests\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
